{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "java -Xmx448m -Xss256k -XX:+UseSerialGC -XX:MaxMetaspaceSize=144m -XX:+UseCompressedOops -jar /app/app.jar",
    "restartPolicyType": "NEVER",
    "healthcheckPath": "/actuator/health",
    "healthcheckTimeout": 300
  }
}
